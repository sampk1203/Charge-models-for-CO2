velocity all create 300.0 4928459 rot yes dist gaussian

#---------------------------------------------------------------
# Compute temperature and pressure
compute myTemp all temp
compute myPress all pressure myTemp

# Set output frequency (must match for thermo and fixes)
variable out_freq equal 100

# CUMULATIVE AVERAGING (strictly cumulative, updates every out_freq steps)
fix ave_temp all ave/time 1 ${out_freq} ${out_freq} c_myTemp ave running
fix ave_temp all ave/time 1 100 ${out_freq} c_myTemp ave running
fix ave_temp all ave/time 1 100 100 c_myTemp ave running
fix ave_press all ave/time 1 ${out_freq} ${out_freq} c_myPress ave running
fix ave_press all ave/time 1 100 ${out_freq} c_myPress ave running
fix ave_press all ave/time 1 100 100 c_myPress ave running

# Thermodynamic output (now includes cumulative averages)
thermo_style custom step temp press f_ave_temp f_ave_press vol density
thermo_modify flush yes
thermo ${out_freq}
thermo 100

# Equilibration in NVT
fix nvt_equil all nvt temp 300.0 300.0 100.0
timestep 0.0005
#run 200000
unfix ave_temp
unfix ave_press
reset_timestep 0
# ---------------------------------------------------------------
# IR Spectrum Calculation
# WARNING: System must have 0 net charge for dipole calculation
compute 1 all property/atom q xu yu zu
variable dipolex atom c_1[1]*c_1[2]
variable dipoley atom c_1[1]*c_1[3]
variable dipolez atom c_1[1]*c_1[4]
compute dxtot all reduce sum v_dipolex
compute dytot all reduce sum v_dipoley
compute dztot all reduce sum v_dipolez
variable totaldipolex equal c_dxtot
variable totaldipoley equal c_dytot
variable totaldipolez equal c_dztot
# Print dipole moment components with proper formatting
variable mytime equal step*dt
#fix printdipole all ave/time 1 1 2 v_mytime v_totaldipolex v_totaldipoley v_totaldipolez file dipole_qeq.txt mode scalar format %.10f
#fix printdipole all print 1 v_mytime v_totaldipolex v_totaldipoley v_totaldipolez file dipole.txt mode scalar format "%.3f %10.10f %10.10f %10.10f" timestep no
fix printdipole all print 1 """$(v_mytime)  $(v_totaldipolex)  $(v_totaldipoley)  $(v_totaldipolez) """ title "" file dipole_qeq.txt screen no

reset_timestep 0
dump 1 all custom 100 dump.co2.qeq.lammpstrj id type x y z q
thermo_style custom step temp press
