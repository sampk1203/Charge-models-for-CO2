fix 1 all qeq/shielded 1 1 1.0e-6 200 qeq.file3.txt

# Neighbor settings
neighbor        15.0 bin
neigh_modify    delay 0 every 1 check yes
# ---------------------------------------------------------------
# Initial minimization and equilibration
min_style cg
minimize 1.0e-10 1.0e-10 1000 10000
